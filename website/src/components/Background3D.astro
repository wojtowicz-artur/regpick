---
import CanvasWrapper from './3d/CanvasWrapper.svelte';
---

<div class="hero-canvas">
  <CanvasWrapper client:load />
</div>

<style>
  .hero-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    overflow: hidden;
    pointer-events: none; /* Let clicks pass through to the hero content */
  }
</style>
