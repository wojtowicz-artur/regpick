---

---

<canvas id="bg3d" class="hero-canvas"></canvas>

<script>
    const canvas = document.getElementById("bg3d") as HTMLCanvasElement;
    const ctx = canvas.getContext("2d")!;

    let width = 0;
    let height = 0;
    let mouseX = -1000;
    let mouseY = -1000;
    let animId = 0;

    // Check theme
    function isDark() {
        return document.documentElement.dataset.theme !== "light";
    }

    function resize() {
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        width = window.innerWidth;
        height = window.innerHeight;
        canvas.width = width * dpr;
        canvas.height = height * dpr;
        canvas.style.width = width + "px";
        canvas.style.height = height + "px";
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    // Particles
    interface Particle {
        x: number;
        y: number;
        z: number;
        vx: number;
        vy: number;
        size: number;
        opacity: number;
    }

    const particles: Particle[] = [];
    const PARTICLE_COUNT = 45;

    function initParticles() {
        particles.length = 0;
        for (let i = 0; i < PARTICLE_COUNT; i++) {
            particles.push({
                x: Math.random() * 2000 - 500,
                y: Math.random() * 1200 - 200,
                z: Math.random() * 0.8 + 0.2,
                vx: (Math.random() - 0.5) * 0.3,
                vy: (Math.random() - 0.5) * 0.2,
                size: Math.random() * 2 + 0.5,
                opacity: Math.random() * 0.5 + 0.1,
            });
        }
    }

    // Grid settings
    const GRID_LINES = 20;
    const HORIZON_Y = 0.38; // position of the horizon (% of viewport)

    function drawGrid(t: number) {
        const dark = isDark();
        const baseColor = dark ? [52, 211, 153] : [5, 150, 105]; // emerald
        const horizonPx = height * HORIZON_Y;

        // Horizontal perspective lines
        for (let i = 0; i <= GRID_LINES; i++) {
            const ratio = i / GRID_LINES;
            // Exponential spacing for perspective
            const perspY =
                horizonPx + Math.pow(ratio, 2.2) * (height - horizonPx);
            const opacity = dark ? 0.04 + ratio * 0.08 : 0.02 + ratio * 0.04;

            ctx.beginPath();
            ctx.strokeStyle = `rgba(${baseColor[0]}, ${baseColor[1]}, ${baseColor[2]}, ${opacity})`;
            ctx.lineWidth = 0.5 + ratio * 0.5;
            ctx.moveTo(0, perspY);
            ctx.lineTo(width, perspY);
            ctx.stroke();
        }

        // Vertical perspective lines converging to vanishing point
        const vanishX = width * 0.5;
        const vanishY = horizonPx;
        const vertLineCount = 14;
        const spread = width * 1.8;

        for (let i = 0; i <= vertLineCount; i++) {
            const ratio = i / vertLineCount;
            const bottomX = vanishX - spread / 2 + spread * ratio;
            const opacity = dark ? 0.03 : 0.015;

            ctx.beginPath();
            ctx.strokeStyle = `rgba(${baseColor[0]}, ${baseColor[1]}, ${baseColor[2]}, ${opacity})`;
            ctx.lineWidth = 0.5;
            ctx.moveTo(vanishX, vanishY);
            ctx.lineTo(bottomX, height + 50);
            ctx.stroke();
        }
    }

    function drawParticles(t: number) {
        const dark = isDark();

        for (const p of particles) {
            // Move
            p.x += p.vx;
            p.y += p.vy;

            // Wrap around
            if (p.x < -100) p.x = width + 100;
            if (p.x > width + 100) p.x = -100;
            if (p.y < -100) p.y = height + 100;
            if (p.y > height + 100) p.y = -100;

            // Breathe effect
            const breathe = Math.sin(t * 0.001 + p.x * 0.01) * 0.15 + 0.85;
            const finalOpacity = p.opacity * breathe * p.z;

            // Proximity to mouse — glow boost
            const dx = p.x - mouseX;
            const dy = p.y - mouseY;
            const dist = Math.sqrt(dx * dx + dy * dy);
            const mouseBoost = Math.max(0, 1 - dist / 250) * 0.6;

            const totalOpacity = dark
                ? Math.min(finalOpacity + mouseBoost, 1)
                : Math.min((finalOpacity + mouseBoost) * 0.5, 0.6);

            const r = dark ? 52 : 5;
            const g = dark ? 211 : 150;
            const b = dark ? 153 : 105;

            // Glow
            if (p.size > 1 || mouseBoost > 0.1) {
                const glowRadius = (p.size * 4 + mouseBoost * 12) * p.z;
                const glow = ctx.createRadialGradient(
                    p.x,
                    p.y,
                    0,
                    p.x,
                    p.y,
                    glowRadius,
                );
                glow.addColorStop(
                    0,
                    `rgba(${r}, ${g}, ${b}, ${totalOpacity * 0.4})`,
                );
                glow.addColorStop(1, `rgba(${r}, ${g}, ${b}, 0)`);
                ctx.fillStyle = glow;
                ctx.beginPath();
                ctx.arc(p.x, p.y, glowRadius, 0, Math.PI * 2);
                ctx.fill();
            }

            // Dot
            ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${totalOpacity})`;
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.size * p.z, 0, Math.PI * 2);
            ctx.fill();
        }
    }

    function drawMouseGlow() {
        if (mouseX < -500) return;
        const dark = isDark();
        const radius = 300;
        const opacity = dark ? 0.07 : 0.03;

        const glow = ctx.createRadialGradient(
            mouseX,
            mouseY,
            0,
            mouseX,
            mouseY,
            radius,
        );
        glow.addColorStop(0, `rgba(52, 211, 153, ${opacity})`);
        glow.addColorStop(0.5, `rgba(52, 211, 153, ${opacity * 0.3})`);
        glow.addColorStop(1, `rgba(52, 211, 153, 0)`);
        ctx.fillStyle = glow;
        ctx.fillRect(mouseX - radius, mouseY - radius, radius * 2, radius * 2);
    }

    function animate(t: number) {
        ctx.clearRect(0, 0, width, height);
        drawGrid(t);
        drawParticles(t);
        drawMouseGlow();
        animId = requestAnimationFrame(animate);
    }

    // Init
    resize();
    initParticles();
    animId = requestAnimationFrame(animate);

    // Events
    window.addEventListener("resize", () => {
        resize();
        initParticles();
    });

    window.addEventListener("mousemove", (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
    });

    window.addEventListener("mouseleave", () => {
        mouseX = -1000;
        mouseY = -1000;
    });

    document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
            cancelAnimationFrame(animId);
        } else {
            animId = requestAnimationFrame(animate);
        }
    });
</script>
