---
import Terminal from "./Terminal.astro";
---

<div class="hero-bg"></div>

<div class="custom-hero">
  <div class="hero-content">
    <div class="hero-badge">🚀 v0.3.0 is out!</div>
    <h1>The Registry Picker<br />for Modern Devs</h1>
    <p>
      Browse, select, and install components from any shadcn-compatible
      registry. Blazing fast, fully typed, endlessly extensible.
    </p>
    <div class="hero-buttons">
      <a href="/how_to/" class="btn-primary">Get Started →</a>
      <a href="https://github.com/wojtowicz-artur/regpick" class="btn-secondary"
        >View on GitHub</a
      >
    </div>
  </div>
  <div class="hero-visual">
    <Terminal />
  </div>
</div>
