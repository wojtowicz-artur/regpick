---
import Terminal from './Terminal.astro';
---

<div class="hero-bg"></div>

<div class="custom-hero">
  <div class="hero-content">
    <div class="hero-badge">v0.2.12 is out!</div>
    <h1>The Registry Picker<br/>for Modern Devs</h1>
    <p>Regpick is a blazing fast, lightweight CLI tool to browse, select, and install components from any shadcn-compatible registry.</p>
    <div class="hero-buttons">
      <a href="/how_to/" class="btn-primary">Get Started</a>
      <a href="https://github.com/wojtowicz-artur/regpick" class="btn-secondary">View on GitHub</a>
    </div>
  </div>
  <div class="hero-visual">
    <Terminal />
  </div>
</div>