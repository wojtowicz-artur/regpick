{
  "name": "regpick",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight CLI for selecting and installing registry entries.",
  "type": "module",
  "bin": {
    "regpick": "./bin/regpick.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "start": "node ./dist/index.js",
    "dev": "tsx ./src/index.ts",
    "init": "node ./dist/index.js init",
    "list": "node ./dist/index.js list",
    "add": "node ./dist/index.js add",
    "validate:tebra": "node ./dist/index.js list ../../tebra-icon-registry/registry"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "cosmiconfig": "^9.0.0",
    "diff": "^8.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^2.1.8"
  }
}
