{
  "name": "regpick",
  "version": "0.2.5",
  "description": "Lightweight CLI for selecting and installing registry entries.",
  "type": "module",
  "files": [
    "dist",
    "bin",
    "regpick.config.schema.json"
  ],
  "keywords": [
    "cli",
    "registry",
    "shadcn",
    "components"
  ],
  "author": "",
  "license": "MIT",
  "bin": {
    "regpick": "./bin/regpick.js"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "release": "release-it",
    "start": "node ./dist/index.mjs",
    "dev": "tsx ./src/index.ts",
    "init": "node ./dist/index.mjs init",
    "list": "node ./dist/index.mjs list",
    "add": "node ./dist/index.mjs add",
    "validate:tebra": "node ./dist/index.mjs list ../../tebra-icon-registry/registry"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "cosmiconfig": "^9.0.0",
    "diff": "^8.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/diff": "^7.0.2",
    "@types/node": "^24.3.0",
    "release-it": "^19.2.4",
    "tsdown": "^0.21.0-beta.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^2.1.8"
  }
}
