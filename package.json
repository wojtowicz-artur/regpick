{
  "name": "regpick",
  "version": "0.20.1",
  "description": "Lightweight CLI for selecting and installing registry entries.",
  "keywords": [
    "cli",
    "component-library",
    "component-registry",
    "components",
    "copy",
    "design-system",
    "developer-tool",
    "frontend-tooling",
    "icon-registry",
    "package-installer",
    "react-components",
    "registry",
    "shadcn",
    "shadcn-ui",
    "svg-icons",
    "tailwind",
    "ui-components"
  ],
  "license": "MIT",
  "author": "",
  "bin": {
    "regpick": "./bin/regpick.js"
  },
  "files": [
    "dist",
    "bin",
    "regpick.config.schema.json"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "exports": {
    ".": "./dist/index.mjs"
  },
  "scripts": {
    "docs:dev": "npm run dev --prefix website",
    "docs:build": "npm run build --prefix website",
    "build": "npm run typecheck && npm run lint && tsdown",
    "fmt": "oxfmt",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run src/**/*.integration.test.ts",
    "release": "release-it",
    "start": "node ./dist/index.mjs",
    "dev": "tsx ./src/index.ts",
    "init": "node ./dist/index.mjs init",
    "list": "node ./dist/index.mjs list",
    "add": "node ./dist/index.mjs add",
    "validate:tebra": "node ./dist/index.mjs list ../../tebra-icon-registry/registry",
    "prepare": "husky"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "diff": "^8.0.3",
    "effect": "^3.19.19",
    "memfs": "^4.56.10",
    "unconfig": "^7.5.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/node": "^24.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "release-it": "^19.2.4",
    "tsdown": "^0.21.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.12.0"
  }
}
