{
  "name": "regpick",
  "version": "0.6.3",
  "description": "Lightweight CLI for selecting and installing registry entries.",
  "type": "module",
  "main": "./dist/index.mjs",
  "exports": {
    ".": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "bin",
    "regpick.config.schema.json"
  ],
  "keywords": [
    "cli",
    "component-registry",
    "component-library",
    "developer-tool",
    "design-system",
    "frontend-tooling",
    "icon-registry",
    "react-components",
    "shadcn",
    "shadcn-ui",
    "svg-icons",
    "tailwind",
    "ui-components",
    "package-installer",
    "registry",
    "components",
    "copy"
  ],
  "author": "",
  "license": "MIT",
  "bin": {
    "regpick": "./bin/regpick.js"
  },
  "scripts": {
    "docs:dev": "npm run dev --prefix website",
    "docs:build": "npm run build --prefix website",
    "build": "tsdown",
    "lint": "oxlint src",
    "test": "vitest run",
    "release": "release-it",
    "start": "node ./dist/index.mjs",
    "dev": "tsx ./src/index.ts",
    "init": "node ./dist/index.mjs init",
    "list": "node ./dist/index.mjs list",
    "add": "node ./dist/index.mjs add",
    "validate:tebra": "node ./dist/index.mjs list ../../tebra-icon-registry/registry",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "diff": "^8.0.3",
    "unconfig": "^7.5.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/diff": "^7.0.2",
    "@types/node": "^24.3.0",
    "husky": "^9.1.7",
    "oxlint": "^1.50.0",
    "release-it": "^19.2.4",
    "tsdown": "^0.21.0-beta.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  }
}
